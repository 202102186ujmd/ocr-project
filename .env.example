# ---------------------------------------------------------------
# OCR Project – variables de entorno de ejemplo
# Copia este archivo a .env y ajusta los valores.
# ---------------------------------------------------------------

# Modelo Paligemma a usar (HuggingFace model ID)
PALIGEMMA_MODEL=google/paligemma-3b-pt-448

# Dispositivo de cómputo: "cuda" para GPU, "cpu" para procesador
DEVICE=cuda

# Tipo de dato para inferencia: "float16" (GPU) o "float32" (CPU)
DTYPE=float16

# Activar cuantización int8 para reducir VRAM (requiere bitsandbytes)
# "true" o "false"
USE_INT8=false

# Directorio donde se guardan temporalmente las imágenes subidas
UPLOAD_DIR=./uploads

# Tamaño máximo de archivo permitido en bytes (10 MB por defecto)
MAX_UPLOAD_SIZE=10485760

# Número máximo de tokens generados por el modelo en cada inferencia
MAX_NEW_TOKENS=512
